{
  "name": "coaching-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace @coaching-app/web run dev",
    "build": "npm --workspaces run build",
    "build:api": "npm --workspace apps/api run build",
    "build:web": "npm --workspace @coaching-app/web run build",
    "typecheck": "npm --workspaces run typecheck",
    "typecheck:api": "npm --workspace apps/api run typecheck",
    "typecheck:web": "npm --workspace @coaching-app/web run typecheck",
    "test:api": "npm --workspace apps/api run test",
    "test:web": "npm --workspace @coaching-app/web run test",
    "db:migrate": "npm --workspace apps/api run db:migrate",
    "api:start": "npm --workspace apps/api run start"
  },
  "devDependencies": {
    "ssh2": "^1.17.0"
  }
}
