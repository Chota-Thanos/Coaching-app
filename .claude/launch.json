{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:api"],
      "port": 4000
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:web"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "mobile",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "--release", "-d", "web-server", "--web-port=5050", "--web-hostname=0.0.0.0"],
      "cwd": "upsc_test_series",
      "port": 5050
    },
    {
      "name": "mobile-debug",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "web-server", "--web-port=5051", "--web-hostname=0.0.0.0"],
      "cwd": "upsc_test_series",
      "port": 5051
    }
  ]
}
