NODE_ENV=development
HOST=0.0.0.0
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/coaching_app
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_IN=8h

# Web build-time API target (REQUIRED in production).
# Next.js inlines NEXT_PUBLIC_* vars into the client bundle at build time.
# If unset when `npm run build` runs, the browser falls back to localhost
# and all client-side API calls break. Must be set before every prod build.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Razorpay Payment Gateway
# When BOTH are set, the web app runs real Razorpay checkout (order-create +
# signature verification). When either is missing, payments run in "simulated"
# mode (no real money moves) so dev/staging still works end-to-end.
# - KEY_ID (rzp_test_* / rzp_live_*) is public and returned to the browser.
# - KEY_SECRET is a SECRET; keep it server-side only, never expose to the client.
# Get both from Razorpay Dashboard -> Settings -> API Keys.
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Webhook secret — separate from the API key secret. Set it when creating the
# webhook in Razorpay Dashboard -> Settings -> Webhooks. The endpoint
# POST /api/v1/billing/razorpay/webhook verifies each event's signature against
# this. Recommended event: order.paid (also handles payment.captured).
# RAZORPAY_WEBHOOK_SECRET=your_webhook_signing_secret

# Google Sign-In (OAuth 2.0)
# The backend validates the ID token's audience against these client IDs. Create
# them in Google Cloud Console -> APIs & Services -> Credentials. Client IDs are
# NOT secret (the web one is exposed to the browser); no client SECRET is needed
# for this ID-token flow.
# - GOOGLE_CLIENT_ID_WEB: the "Web application" OAuth client. Also used by the
#   mobile app as serverClientId, and by the web app (see NEXT_PUBLIC_ below).
# - GOOGLE_CLIENT_ID_ANDROID / _IOS: the platform OAuth clients (optional; only
#   needed if you want the backend to also accept tokens audienced to them).
# If NONE are set, the backend skips the audience check (fine for local dev).
# GOOGLE_CLIENT_ID_WEB=xxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_ID_ANDROID=xxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_ID_IOS=xxxxxxxx.apps.googleusercontent.com

# Web browser needs the SAME web client ID at build time to render the Google
# button (Next.js inlines NEXT_PUBLIC_* into the client bundle). Set this in the
# web env (apps/web/.env or the root .env used for the web build).
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# AI providers for current-affairs generation & OCR question import (optional,
# but at least one is needed for those features to work — otherwise disabled).
# GEMINI_API_KEY=your_gemini_api_key
# OPENAI_API_KEY=your_openai_api_key
# GOOGLE_CLOUD_KEY_JSON={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# VERTEX_AI_PROJECT_ID=your_gcp_project_id
# VERTEX_AI_LOCATION=us-central1

# Agora video (optional - used by mentorship 1:1 calls and Study Plan live
# classes; without these, channels join in Agora's unauthenticated testing
# mode instead of using signed tokens)
# AGORA_APP_ID=your_agora_app_id
# AGORA_APP_CERTIFICATE=your_agora_app_certificate

# Outbound email (SMTP) — powers email verification and password reset.
# Provider-agnostic: works with Resend, AWS SES, SendGrid, Postmark, Gmail, or
# any SMTP relay. If SMTP_HOST is unset the mailer logs the message instead of
# sending (so dev/staging keeps working) and password reset silently no-ops —
# set these before relying on account recovery in production.
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=resend
# SMTP_PASSWORD=your_smtp_password_or_api_key
# MAIL_FROM=WayToIAS <no-reply@waytoias.com>
# Base URL used to build links inside emails (verification / reset).
# PUBLIC_WEB_URL=https://waytoias.com

# Media uploads (optional - defaults apply if unset)
# MEDIA_MAX_FILE_SIZE_BYTES=10485760
# MEDIA_UPLOAD_DIR=./uploads
# MEDIA_PUBLIC_PATH=/uploads
